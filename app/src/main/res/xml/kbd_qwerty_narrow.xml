<?xml version="1.0" encoding="utf-8"?>
<!--
/* Narrow QWERTY layout for foldable cover screens (7 keys per row). */
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res-auto"
    android:keyWidth="14.2857%p" android:horizontalGap="0px" android:verticalGap="@dimen/key_bottom_gap">

    <!-- Row 1: Q W E R T Y U -->
    <Row android:rowEdgeFlags="top">
        <Key android:keyLabel="q" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="1" android:keyEdgeFlags="left" />
        <Key android:keyLabel="w" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="2" />
        <Key android:keyLabel="e" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="3" />
        <Key android:keyLabel="r" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="4" />
        <Key android:keyLabel="t" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="5" />
        <Key android:keyLabel="y" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="6" />
        <Key android:keyLabel="u" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="7" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 2: I O P A S D F -->
    <Row>
        <Key android:keyLabel="i" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="8" android:keyEdgeFlags="left" />
        <Key android:keyLabel="o" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="9" />
        <Key android:keyLabel="p" android:popupKeyboard="@xml/kbd_popup_template" android:popupCharacters="0" />
        <Key android:keyLabel="a" />
        <Key android:keyLabel="s" />
        <Key android:keyLabel="d" />
        <Key android:keyLabel="f" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 3: G H J K L N M -->
    <Row>
        <Key android:keyLabel="g" android:keyEdgeFlags="left" />
        <Key android:keyLabel="h" />
        <Key android:keyLabel="j" />
        <Key android:keyLabel="k" />
        <Key android:keyLabel="l" />
        <Key android:keyLabel="n" />
        <Key android:keyLabel="m" android:keyEdgeFlags="right" />
    </Row>

    <!-- Row 4: Shift + Z X C V B + Delete -->
    <Row>
        <Key android:codes="@integer/key_shift" android:keyIcon="@drawable/sym_keyboard_shift" android:iconPreview="@drawable/sym_keyboard_feedback_shift" android:keyWidth="17.14%p" android:isModifier="true" android:isSticky="true" android:keyEdgeFlags="left" />
        <Key android:keyLabel="z" android:keyWidth="13.14%p" />
        <Key android:keyLabel="x" android:keyWidth="13.14%p" />
        <Key android:keyLabel="c" android:keyWidth="13.14%p" />
        <Key android:keyLabel="v" android:keyWidth="13.14%p" />
        <Key android:keyLabel="b" android:keyWidth="13.14%p" />
        <Key android:codes="@integer/key_delete" android:keyIcon="@drawable/sym_keyboard_delete" android:iconPreview="@drawable/sym_keyboard_feedback_delete" android:keyWidth="17.14%p" android:isModifier="true" android:isRepeatable="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- Bottom rows (same pattern as kbd_qwerty.xml) -->
    <Row android:keyboardMode="@+id/mode_normal" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_url" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_email" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_im" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:keyLabel="&#x263A;" android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_emoji" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_webentry" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="27.14%p" android:isModifier="true" />
        <Key android:codes="@integer/key_tab" android:keyIcon="@drawable/sym_keyboard_tab" android:iconPreview="@drawable/sym_keyboard_feedback_tab" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>

    <!-- with_settings_key variants -->
    <Row android:keyboardMode="@+id/mode_normal_with_settings_key" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_url_with_settings_key" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_email_with_settings_key" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_im_with_settings_key" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="37.14%p" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:keyLabel="&#x263A;" android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_emoji" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
    <Row android:keyboardMode="@+id/mode_webentry_with_settings_key" android:keyWidth="14.2857%p" android:rowEdgeFlags="bottom">
        <Key android:codes="@integer/key_symbol" android:keyLabel="@string/label_symbol_key" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="left" />
        <Key android:codes="@integer/key_next_language" android:keyLabel="@string/label_lang_switch" android:isModifier="true" />
        <Key android:codes="@integer/key_space" android:keyIcon="@drawable/sym_keyboard_space" android:iconPreview="@drawable/sym_keyboard_feedback_space" android:keyWidth="27.14%p" android:isModifier="true" />
        <Key android:codes="@integer/key_tab" android:keyIcon="@drawable/sym_keyboard_tab" android:iconPreview="@drawable/sym_keyboard_feedback_tab" android:isModifier="true" />
        <Key android:keyLabel="." android:keyIcon="@drawable/hint_popup" android:popupKeyboard="@xml/popup_punctuation" android:isModifier="true" />
        <Key android:codes="@integer/key_return" android:keyIcon="@drawable/sym_keyboard_return" android:iconPreview="@drawable/sym_keyboard_feedback_return" android:keyWidth="17.14%p" android:isModifier="true" android:keyEdgeFlags="right" />
    </Row>
</Keyboard>
