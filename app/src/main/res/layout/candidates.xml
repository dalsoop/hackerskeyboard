<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/candidate_strip_height"
        android:background="@drawable/keyboard_suggest_strip"
        >

    <org.pocketworkstation.pckeyboard.CandidateView
        android:id="@+id/candidates"
        android:layout_width="0dp"
        android:layout_height="@dimen/candidate_strip_height"
        android:layout_weight="1"
        android:fadingEdge="horizontal"
        android:fadingEdgeLength="@dimen/candidate_strip_fading_edge_length"
        />

    <!-- Action toolbar: shown when no suggestions are active -->
    <LinearLayout
        android:id="@+id/action_toolbar"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/candidate_strip_height"
        android:gravity="center"
        android:visibility="gone"
        >

        <TextView
            android:id="@+id/action_select_all"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/action_select_all"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="#555555" />

        <TextView
            android:id="@+id/action_cut"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/action_cut"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="#555555" />

        <TextView
            android:id="@+id/action_copy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/action_copy"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:background="#555555" />

        <TextView
            android:id="@+id/action_paste"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/action_paste"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            />

    </LinearLayout>

</LinearLayout>
